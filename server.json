{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vedangvatsa123/cvinbio",
  "description": "Search professional profiles from the CVin.Bio talent database.",
  "repository": {
    "url": "https://github.com/vedangvatsa123/PDFtoWebsite",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@cvinbio/mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Supabase project URL",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "SUPABASE_URL"
        },
        {
          "description": "Supabase service role key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "SUPABASE_KEY"
        }
      ]
    }
  ]
}