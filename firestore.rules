
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    // Profile data lives directly on users/{userId}
    match /users/{userId} {
      allow get: if true;          // Public reads for profile pages
      allow list: if false;        // No listing all users
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/workExperience/{experienceId} {
      allow read, list: if true;
      allow write: if isOwner(userId);
    }

    match /users/{userId}/education/{educationId} {
      allow read, list: if true;
      allow write: if isOwner(userId);
    }

    match /users/{userId}/customSections/{sectionId} {
      allow read, list: if true;
      allow write: if isOwner(userId);
    }

    match /users/{userId}/dailyViews/{dateId} {
      allow read: if isOwner(userId);
      allow write: if false; // Server-side only via Admin SDK
    }

    match /themes/{themeId} {
      allow get: if true;
      allow list: if true;
      allow write: if false;
    }

    // Slim slug lookup: only stores {userId}
    match /slugs/{slug} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
